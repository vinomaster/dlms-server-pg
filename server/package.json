{
  "name": "dlms-server-pg",
  "version": "1.0.0",
  "description": "DLMS REST API server – AWS Polyglot (PostgreSQL + OpenSearch) edition",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsoa spec-and-routes && tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node build/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "migrate": "node build/db/migrate.js",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "dlms-base-pg": "^1.0.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@opensearch-project/opensearch": "^2.7.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-openidconnect": "^0.1.2",
    "pg": "^8.11.5",
    "pg-migrate": "^1.0.0",
    "tsoa": "^6.4.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.14.2",
    "@types/passport": "^1.0.16",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
