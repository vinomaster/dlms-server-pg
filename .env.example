# ── PostgreSQL (System of Record) ─────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=dlms
PG_USER=dlms
PG_PASS=dlms
PG_SSL=false
PG_POOL_MAX=10

# ── OpenSearch (Search Layer) ──────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=http://localhost:9200
# OPENSEARCH_USER=dlms-admin
# OPENSEARCH_PASS=DlmsLocal@123!
# OPENSEARCH_USE_AWS_AUTH=false
OPENSEARCH_REPLICAS=0    # 0 for single-node local dev; 1+ for production

# ── S3 / LocalStack ────────────────────────────────────────────────────────────
ATTACHMENTS_BUCKET=dlms-attachments
BACKUP_BUCKET=dlms-backups
BACKUP_PREFIX=dlms-backups
S3_ENDPOINT=http://localhost:4566   # Remove this line in production
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=test            # Only for LocalStack
# AWS_SECRET_ACCESS_KEY=test        # Only for LocalStack

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
CORS_ORIGIN=*
IDS_ADMIN=admin
API_TOKEN=dev-token-change-me

# ── Auth ───────────────────────────────────────────────────────────────────────
BASIC_AUTH_ENABLED=true
OAUTH_ENABLED=false
SESSION_SECRET=change-me-in-production

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_SERVER=localhost
EMAIL_PORT=25
